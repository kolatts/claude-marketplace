{
  "eval_id": 0,
  "eval_name": "speaker-bio",
  "prompt": "Write a speaker bio for Sunny for a tech conference.",
  "assertions": [
    {
      "id": "mentions_medicine",
      "description": "Mentions medical school or Case Western",
      "type": "regex",
      "pattern": "(?i)(medical school|Case Western|medicine|clinical)"
    },
    {
      "id": "mentions_music",
      "description": "Mentions Deadiron or music/band",
      "type": "regex",
      "pattern": "(?i)(Deadiron|metal band|band|music)"
    },
    {
      "id": "no_passion_language",
      "description": "Does not use 'passionate about' or 'leverages'",
      "type": "not_regex",
      "pattern": "(?i)(passionate about|leverages|seasoned|thought leader)"
    },
    {
      "id": "staff_engineer_title",
      "description": "Uses 'Staff Engineer' title correctly",
      "type": "regex",
      "pattern": "Staff Engineer"
    },
    {
      "id": "third_career_framing",
      "description": "Frames arc as multiple careers with lightness, not gravitas",
      "type": "manual",
      "criteria": "Does the bio make light of the three-career arc rather than treating it with heavy seriousness? Does it avoid 'came to software by way of' and 'load-bearing'?"
    }
  ]
}
